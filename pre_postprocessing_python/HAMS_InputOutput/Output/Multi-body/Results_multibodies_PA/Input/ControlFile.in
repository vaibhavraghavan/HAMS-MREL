   --------------HAMS Control file---------------
   
   Waterdepth   120.D0                                          # Finite depth

   #Start Definition of Wave Frequencies
    0_inf_frequency_limits      1                             # 0: not to include; 1: to include; This will calculate the added mass for zero and infinite frequency
    Input_frequency_type        2                             # Wave frequency is used here
    Output_frequency_type       4                             # Wave frequency output is chosen
    Number_of_frequencies      -100
    Minimum_frequency_Wmin    0.0125D0
    Frequency_step            0.0125D0
	#End Definition of Wave Frequencies
	
   # Start of definition of bodies for multi-body interaction
    Number_of_bodies          3
    LCS_1                     13.000        0.000        0.000        0.000             # The first three entries refer to the x, y and z coordinates of the origin of LCS w.r.t origin of GCS and the fourth entry refers to the rotation of LCS x-axis w.r.t GCS x-axis
    LCS_2                     0.000        7.500        0.000        0.000   
    LCS_3                     0.000        -7.500        0.000        0.000	  
   # End of definition of bodies for multi-body interaction	

   #Start Definition of Wave Headings
    Number_of_headings        1                               # Single wave heading is used (parallel to x axis)
    0.D0
   #End Definition of Wave Headings

    Reference_body_center_1       13.000        0.000        0.000                              # Rotation center first body
	Reference_body_center_2       0.000        7.500        0.000                              # Rotation center second body
	Reference_body_center_3       0.000        -7.500        0.000                              # Rotation center third body
    Reference_body_length   1.D0                              # Default value is taken for now
    Wave_diffrac_solution    1
    If_remove_irr_freq       0                                # No waterplane needed. No removal of irregular frequencies.
    Number of threads        32                                # Taken as the default value 

   ----------End HAMS Control file---------------
   
   
   Input_frequency_type options: 
   1--deepwater wave number; 2--finite-depth wave number; 3--wave frequency; 4--wave period; 5--wave length
   Output_frequency_type options: same as Input_frequency_type options

   
